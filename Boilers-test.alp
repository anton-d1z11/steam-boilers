		<JavaClass>
			<Id>1781256319552</Id>
			<Name><![CDATA[Boiler]]></Name>
			<Text><![CDATA[/**
 * Boiler
 */	
public class Boiler implements Serializable {
	double minLoad, maxLoad, kpd, pressure, tEco1Out, tEco2Out, initialLoad;
    /**
     * Конструктор по умолчанию
     */
    public Boiler(double minLoad, double maxLoad, double kpd, double pressure, double tEco1Out, double tEco2Out) {
    	this.minLoad =  minLoad;
    	this.maxLoad = maxLoad;
    	this.kpd = kpd;
    	this.pressure = pressure;
    	this.tEco1Out = tEco1Out;
    	this.tEco2Out = tEco2Out;
    }
    
    public void setInitialLoad(double initial) {
    	this.initialLoad = initial;
    }
    
    /* private static double[] getAllLoadBoils(Boiler[] boilerAll) {
		double sumMin = 0;
		double sumMax = 0;
		for(Boiler oneBoiler: boilerAll) {
			sumMin += oneBoiler.minLoad;
			sumMax += oneBoiler.maxLoad;
		}
		double[] sum = {sumMin, sumMax};
		return sum;
	} */

	@Override
	public String toString() {
		return super.toString();
	}

	/**
	 * Это число используется при сохранении состояния модели<br>
	 * Его рекомендуется изменить в случае изменения класса
	 */ 
	private static final long serialVersionUID = 1L;

}]]></Text>
		</JavaClass>
		<!--   =========   Java Class   ========  -->
		<JavaClass>
			<Id>1781258617566</Id>
			<Name><![CDATA[Procedures]]></Name>
			<Text><![CDATA[/**
 * Procedures
 */	
public class Procedures implements Serializable {

    /**
     * Конструктор по умолчанию
     */
    public Procedures() {
    	
    }
    
    public static void setInitialLoad(ArrayList<Boiler> boilers, double load) {
    	double sumMin = 0;
		double sumMax = 0;
		double l;
		for(Boiler oneBoiler: boilers) {
			sumMin += oneBoiler.minLoad;
			sumMax += oneBoiler.maxLoad;
		}
		
		for(Boiler oneBoiler: boilers) {
			l = load * (oneBoiler.maxLoad / sumMax);
			l = Math.max(oneBoiler.minLoad, Math.min(oneBoiler.maxLoad, l));
			oneBoiler.setInitialLoad(Math.round(l));
		}
    }

	/**
	 * Это число используется при сохранении состояния модели<br>
	 * Его рекомендуется изменить в случае изменения класса
	 */ 
	private static final long serialVersionUID = 1L;

}]]></Text>
		</JavaClass>
