			<Import><![CDATA[import com.hummeling.if97.IF97;]]></Import>
			<StartupCode><![CDATA[viewArea.navigateTo();
pushBoiler(new Boiler(4000, 11000, 93.8, 11, 80, 120));
pushBoiler(new Boiler(3000, 8000, 93.8, 11, 80, 120));
pushBoiler(new Boiler(5000, 14000, 93.8, 11, 80, 120));
pushBoiler(new Boiler(2000, 6000, 93.8, 11, 80, 120));
pushBoiler(new Boiler(7000, 16000, 93.8, 11, 80, 120));
pushBoiler(new Boiler(3500, 7800, 93.8, 11, 80, 120));
Procedures.setInitialLoad(boilers, vapourAll);
if(boilers.get(0)!= null) initialLine1(boilers.get(0));
if(boilers.get(1)!= null) initialLine2(boilers.get(1));
if(boilers.get(2)!= null) initialLine3(boilers.get(2));
if(boilers.get(3)!= null) initialLine4(boilers.get(3));
if(boilers.get(4)!= null) initialLine5(boilers.get(4));
if(boilers.get(5)!= null) initialLine6(boilers.get(5));
]]></StartupCode>
